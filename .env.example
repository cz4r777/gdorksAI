# gdorksAI configuration. Copy to `.env` and edit.

# ---- AI backend ----
# Primary: Ollama (must be running on the host below)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL_QUERY=llama3.1:8b-instruct
OLLAMA_MODEL_TRIAGE=llama3.1:8b-instruct
OLLAMA_MODEL_PIVOT=llama3.1:8b-instruct
OLLAMA_MODEL_REPORT=qwen2.5:14b-instruct

# Fallback: Groq. Leave GROQ_API_KEY blank to stay fully local (no outbound calls).
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ---- Web app ----
HOST=127.0.0.1
PORT=8000
RELOAD=true

# ---- Scope / ethics ----
# Path to the engagement scope file. Targets outside this list are refused.
SCOPE_FILE=runtime/scope.json

# ---- Dork data ----
# Path to the dork corpus directory. Resolved by app/core/dorks.py at startup.
# Files/folders to be parsed are configured in docs/ARCHITECTURE.md.
DORKS_DATA_PATH=data/dorks

# ---- Telemetry (off by default) ----
TELEMETRY_ENABLED=false
TELEMETRY_DB=runtime/telemetry.db
